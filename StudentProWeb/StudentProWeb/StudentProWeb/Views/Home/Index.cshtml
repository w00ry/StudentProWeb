    </style>
</head>
<body>

    <aside>
        <h1>Student Pro</h1>
        <nav>
            <ul>
                <li><a href="/Home/Index">Ana Panel</a></li>
                <li><a href="/Home/Course" class="active">Derslerim ve Notlarım</a></li>
                <li><a href="/Home/Assignments">Ödevlerim</a></li>
                <li><a href="/Home/Exams">Sınav Takvimi</a></li>
                <li><a href="/Account/Login">Çıkış Yap</a></li>
            </ul>
        </nav>
    </aside>

    <main>
        <header>
            <div>
                <h2 style="margin: 0;">Kontrol Paneli</h2>
                <p style="margin: 5px 0 0 0; color: #7f8c8d;">Sistem Özeti ve İstatistikler</p>
            </div>
            <div class="user-info">
                <strong>@Context.Session.GetString("LoggedStudentName")</strong>
            </div>
        </header>

        <div class="welcome-banner">
            <h2>Hoş Geldin, @Context.Session.GetString("LoggedStudentName")! 👋</h2>
            <p>Student Pro eğitim otomasyonuna hoş geldin. Aşağıdan güncel akademik durumunun özetini inceleyebilirsin.</p>
        </div>

        <div class="dashboard-grid">
            <div class="stat-card blue" onclick="window.location.href='/Home/Course'" style="cursor: pointer;" title="Dersleri Yönet">
                <div class="stat-info">
                    <h3>@ViewBag.TotalCourses</h3>
                    <p>Aktif Ders Sayısı</p>
                </div>
                <div class="stat-icon">📚</div>
            </div>

            <div class="stat-card green" onclick="window.location.href='/Home/Assignments'" style="cursor: pointer;" title="Ödevlere Git">
                <div class="stat-info">
                    <h3>@ViewBag.PendingAssignments</h3>
                    <p>Görev ve Ödevler</p>
                </div>
                <div class="stat-icon">📝</div>
            </div>

            <div class="stat-card purple" onclick="window.location.href='/Home/Exams'" style="cursor: pointer;" title="Sınav Takvimine Git">
                <div class="stat-info">
                    <h3>@ViewBag.UpcomingExams</h3>
                    <p>Yaklaşan Sınavlar</p>
                </div>
                <div class="stat-icon">⏰</div>
            </div>
        </div>

    </main>

</body>
</html>