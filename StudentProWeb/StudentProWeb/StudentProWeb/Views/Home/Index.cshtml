@using Microsoft.AspNetCore.Http
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Pro - Ana Panel</title>
    <style>
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #34495e;
            --accent-color: #3498db;
            --bg-color: #f4f6f9;
            --text-color: #333;
            --card-bg: #ffffff;
        }

        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background-color: var(--bg-color); color: var(--text-color); display: flex; min-height: 100vh; }
        
        aside { width: 250px; background-color: var(--primary-color); color: white; padding: 20px 0; }
        aside h1 { text-align: center; font-size: 1.5rem; margin-bottom: 30px; color: var(--accent-color); }
        aside nav ul { list-style: none; padding: 0; }
        aside nav ul li a { display: block; padding: 15px 20px; color: white; text-decoration: none; transition: background 0.3s; }
        aside nav ul li a:hover { background-color: var(--secondary-color); border-left: 4px solid var(--accent-color); }
        
        main { flex: 1; padding: 30px; }
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #e0e0e0; padding-bottom: 10px; }
        
        /* Dashboard Kart Tasarımları */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background-color: var(--card-bg);
            padding: 25px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 4px solid #ccc;
            transition: transform 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-card.blue { border-color: #3498db; }
        .stat-card.green { border-color: #d29b6c; }
        .stat-card.purple { border-color: #9b59b6; }

        .stat-info h3 { margin: 0; font-size: 2rem; color: var(--primary-color); }
        .stat-info p { margin: 5px 0 0 0; color: #7f8c8d; font-size: 0.95rem; font-weight: 500; }
        
        .stat-icon {
            font-size: 2.5rem;
            opacity: 0.8;
        }

        .welcome-banner {
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
            padding: 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .welcome-banner h2 { margin-top: 0; }
        .welcome-banner p { margin-bottom: 0; font-size: 1.05rem; opacity: 0.9; }

